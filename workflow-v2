<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{

    font-family:'Inter',sans-serif;

    background:#F8FAFC;

    color:#1E293B;

}

.layout{

    display:grid;

    grid-template-columns:
        320px
        1fr
        340px;

    min-height:100vh;

}

/* LEFT PANEL */

.sidebar{

    background:#0F172A;

    color:white;

    padding:24px;

}

.brand{

    display:flex;

    align-items:center;

    gap:12px;

    margin-bottom:30px;

}

.cash-logo{

    width:50px;

    height:50px;

    border-radius:12px;

    background:#00D64F;

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:28px;

    font-weight:700;

}

.brand-title{

    display:flex;

    flex-direction:column;

}

.brand-title h2{

    font-size:18px;

}

.brand-title span{

    font-size:12px;

    opacity:.8;

}

.intake-section{

    margin-top:20px;

}

.intake-section h3{

    margin-bottom:15px;

}

.intake-section label{

    display:block;

    margin-top:12px;

    margin-bottom:5px;

    font-size:13px;

}

.intake-section select{

    width:100%;

    padding:10px;

    border:none;

    border-radius:8px;

}

.primary-btn{

    width:100%;

    margin-top:15px;

    padding:12px;

    border:none;

    border-radius:8px;

    background:#00D64F;

    color:white;

    font-weight:600;

    cursor:pointer;

}

.journey-section{

    margin-top:30px;

}

.journey-section h3{

    margin-bottom:15px;

}

.journey-step{

    background:rgba(255,255,255,.08);

    padding:10px;

    border-radius:8px;

    margin-bottom:8px;

}

.journey-step.active{

    background:#00D64F;

    color:black;

    font-weight:600;

}

/* CENTER */

.main-panel{

    padding:24px;

}

.workflow-header{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-bottom:20px;

}

.workflow-header h2{

    font-size:24px;

}

.status-badge{

    padding:8px 16px;

    border-radius:999px;

    font-size:12px;

    font-weight:600;

}

.ready{

    background:#E2E8F0;

}

.inprogress{

    background:#DBEAFE;

}

.completed{

    background:#DCFCE7;

}

.cancelled{

    background:#FEE2E2;

}

.question-box{

    background:white;

    border-radius:12px;

    padding:20px;

    min-height:140px;

    box-shadow:
        0 2px 8px
        rgba(0,0,0,.05);

}

.choices{

    margin-top:20px;

    display:flex;

    flex-wrap:wrap;

    gap:10px;

}

.choice-btn{

    background:#00D64F;

    color:white;

    border:none;

    border-radius:8px;

    padding:12px 16px;

    cursor:pointer;

}

.script-card{

    margin-top:20px;

    background:white;

    border-radius:12px;

    padding:20px;

    box-shadow:
        0 2px 8px
        rgba(0,0,0,.05);

}

.script-card h3{

    margin-bottom:15px;

}

.script-box{

    line-height:1.7;

    min-height:160px;

}

.workflow-actions{

    margin-top:20px;

    display:flex;

    gap:10px;

}

.secondary-btn{

    padding:12px 16px;

    border:none;

    border-radius:8px;

    cursor:pointer;

    background:#CBD5E1;

}

.danger-btn{

    padding:12px 16px;

    border:none;

    border-radius:8px;

    cursor:pointer;

    background:#DC2626;

    color:white;

}

/* RIGHT */

.resource-panel{

    background:#F1F5F9;

    padding:24px;

}

.resource-card{

    background:white;

    border-radius:12px;

    padding:16px;

    margin-bottom:16px;

}

.resource-card h3{

    margin-bottom:12px;

}

/* MODAL */

.modal{

    position:fixed;

    inset:0;

    background:
        rgba(0,0,0,.5);

    display:flex;

    justify-content:center;

    align-items:center;

}

.hidden{

    display:none;

}

.modal-content{

    background:white;

    width:420px;

    border-radius:12px;

    padding:24px;

}

.modal-content h3{

    margin-bottom:10px;

}

.modal-content select{

    width:100%;

    padding:10px;

    margin-top:10px;

}

.modal-actions{

    display:flex;

    gap:10px;

    margin-top:20px;

}

</style>

</head>

